flowchart TD
    A["<b>Step 1: Export Data</b><br/>162K template rows + 311K dropdown values<br/>from Epic Clarity"] --> B
    B["<b>Step 2: Build Formal Context</b><br/>Deduplicate to ~56K items<br/>Parse names, classify templates + value domains<br/>Output: items x ~300 binary attributes"] --> C
    C["<b>Step 3: Compute Lattice</b><br/>NextClosure algorithm finds all maximal groups<br/>sharing identical properties (2-pass)"] --> D
    D["<b>Step 4: Classify Concepts</b><br/>A = Atomic (~16K) — standalone clinical item<br/>B = Compositional (~1.5K) — has body site qualifier<br/>C = Unmappable (~38K) — no assessment detected"] --> E
    E["<b>Step 5: Generate Mapping CSVs</b><br/>atomic_items.csv + compositional_mapping.csv<br/>+ unmappable_items.csv"] --> F
    F["<b>Step 6: Build mapping.csv</b><br/>Merge FCA outputs + existing hand-curated mappings<br/>B items get multi-row entries (observation + qualifier)"] --> G
    G["<b>Step 7: Validate</b><br/>Completeness, consistency, lattice validity"]
    D -- "C items" --> H["<b>Clinical Review Pass</b><br/>LLM + OHDSI vocab lookups<br/>rescue ~10K items from C"]
    H --> F
